</div>

<div class="container main-container">
  <!-- Header Title & Action -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h3 class="fw-bold m-0">Dashboard Keuangan</h3>
      <p class="text-muted small">Kelola penerimaan dan pengeluaran kas Anda</p>
    </div>
    <div class="d-flex gap-2">
      <!-- Ganti tombol export lama dengan ini -->
