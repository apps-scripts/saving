            <select class="form-select border-start-0 shadow-none fw-bold" id="rowsPerPageSelect" onchange="changeRowsPerPage()" style="cursor:pointer; color: #555;">
              <option value="5" selected>5 baris</option>
              <option value="10">10 baris</option>
              <option value="25">25 baris</option>
              <option value="50">50 baris</option>
