<!-- JS Dependencies -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
  // Global Variables
  let rawData = [];
  let filteredData = [];
  let currentPage = 1;
  let rowsPerPage = 5;
  let fpTanggal, fpStart, fpEnd;
  let modalElement;
  let isEditMode = false;
  let editNo = null;

  // 1. Jalankan inisialisasi saat halaman siap
  document.addEventListener('DOMContentLoaded', () => {
    // Inisialisasi Modal Bootstrap
    modalElement = new bootstrap.Modal(document.getElementById('modalTransaksi'));

    // Definisi elemen
    const searchInput = document.getElementById('searchInput');
    const clearBtn = document.getElementById('clearSearch');

    // Event saat mengetik di kolom pencarian
    searchInput.addEventListener('input', function() {
      // Tampilkan tombol X jika ada teks, sembunyikan jika kosong
      clearBtn.style.display = this.value.length > 0 ? 'block' : 'none';
      
      currentPage = 1;
      applyFilter();
    });

    // Event saat tombol X diklik
    clearBtn.addEventListener('click', function() {
      searchInput.value = '';        // Kosongkan input
      this.style.display = 'none';   // Sembunyikan tombol X sendiri
      
      currentPage = 1;
      applyFilter();                 // Refresh tabel (tampilkan semua data)
      searchInput.focus();           // Kembalikan fokus ke input
    });
    
    // Panggil fungsi inisialisasi
    initDatePickers();
    loadData();
  });

  // 2. Fungsi Inisialisasi Flatpickr
  function initDatePickers() {
    const config = {
      locale: "id",
      dateFormat: "Y-m-d",
      altInput: true,
      altFormat: "d F Y",
      allowInput: true,
      onDayCreate: function(dObj, dStr, fp, dayElem) {
        if (dayElem.dateObj.getDay() === 0 || dayElem.dateObj.getDay() === 6) {
          dayElem.classList.add("weekend-red");
        }
      }
    };

    fpTanggal = flatpickr("#tanggal", { ...config, defaultDate: "today" });
    fpStart = flatpickr("#exportStart", config);
    fpEnd = flatpickr("#exportEnd", config);
  }

  // 3. Ambil Data dari Database
  // Fungsi Pembantu Loading
function toggleFullLoader(show) {
  document.getElementById('fullPageLoader').style.display = show ? 'flex' : 'none';
}

function loadData() {
  // Set tampilan tabel ke loading
  document.getElementById('tableBody').innerHTML = `
    <tr>
      <td colspan="7">
        <div class="loader-container">
          <div class="lux-spinner"></div>
          <div class="text-muted small">Sinkronisasi data...</div>
        </div>
      </td>
    </tr>
  `;

  google.script.run
  .withSuccessHandler((data) => {
    // Cek jika data null atau undefined
    if (!data || data.length === 0) {
      rawData = [];
      filteredData = [];
      document.getElementById('tableBody').innerHTML = '<tr><td colspan="7" class="text-center py-5">Belum ada data transaksi</td></tr>';
      updateDashboard(0, 0, 0);
      toggleFullLoader(false);
      return;
    }

    // Sort aman
    data.sort((a, b) => new Date(a[1]) - new Date(b[1]));
    rawData = data;
    applyFilter();
    toggleFullLoader(false);
  })
  .withFailureHandler((err) => {
    toggleFullLoader(false);
    document.getElementById('tableBody').innerHTML = '<tr><td colspan="7" class="text-center text-danger">Gagal memuat data</td></tr>';
  }).ambilData();
}

  // 4. Filter & Hitung Saldo
  function applyFilter() {
  const key = (document.getElementById('searchInput').value || "").toLowerCase();
  let filtered = rawData.filter(r => (r[3] || "").toLowerCase().includes(key));
  
  let runningBalance = 0;
  let totalMasuk = 0;
  let totalKeluar = 0;

  filteredData = filtered.map((row) => {
    // Proteksi jika row[4] kosong
    let jmlStr = row[4] ? row[4].toString() : "0";
    let jml = parseFloat(jmlStr.replace(/[Rp,. ]/g, '')) || 0;
    
    let masuk = row[2] === 'Penerimaan' ? jml : 0;
    let keluar = row[2] === 'Pengeluaran' ? jml : 0;
    
    totalMasuk += masuk;
    totalKeluar += keluar;
    runningBalance += (masuk - keluar);

    return { 
      noAsli: row[0],
      tanggal: row[1], 
      uraian: row[3], 
      penerimaan: masuk, 
      pengeluaran: keluar, 
      saldo: runningBalance 
    };
  });

  updateDashboard(totalMasuk, totalKeluar, runningBalance);
  renderTable();
}

function updateDashboard(masuk, keluar, saldo) {
  document.getElementById('txtTotalMasuk').innerText = 'Rp ' + masuk.toLocaleString('id-ID');
  document.getElementById('txtTotalKeluar').innerText = 'Rp ' + keluar.toLocaleString('id-ID');
  document.getElementById('txtSaldo').innerText = 'Rp ' + saldo.toLocaleString('id-ID');
}

  // 5. Render Tabel ke HTML
  function renderTable() {
    const tbody = document.getElementById('tableBody');
    tbody.innerHTML = '';
    
    if (filteredData.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="text-center py-5">Tidak ada data transaksi</td></tr>';
      return;
    }

    const start = (currentPage - 1) * rowsPerPage;
    const end = start + rowsPerPage;
    const items = filteredData.slice(start, end);

    items.forEach((item, i) => {
      const tr = document.createElement('tr');
      // Ambil No asli dari data untuk referensi Edit/Hapus
      const dataAsli = rawData.find(r => r[1] === item.tanggal && r[3] === item.uraian);
      const noAsli = dataAsli ? dataAsli[0] : '';

      tr.innerHTML = `
        <td class="text-muted small">${start + i + 1}</td>
        <td>${formatTanggalIndo(item.tanggal)}</td>
        <td style="word-break: break-word;">${item.uraian}</td>
        <td class="text-end text-success fw-bold">${item.penerimaan > 0 ? 'Rp ' + item.penerimaan.toLocaleString('id-ID') : '-'}</td>
        <td class="text-end text-danger fw-bold">${item.pengeluaran > 0 ? 'Rp ' + item.pengeluaran.toLocaleString('id-ID') : '-'}</td>
        <td class="text-end fw-bold bg-light">Rp ${item.saldo.toLocaleString('id-ID')}</td>
        <td class="text-center">
          <div class="btn-group">
            <button class="btn btn-sm btn-outline-primary border-0" onclick="editData('${noAsli}')" title="Edit">
              <i class="fas fa-edit"></i>
            </button>
            <button class="btn btn-sm btn-outline-danger border-0" onclick="konfirmasiHapus('${noAsli}')" title="Hapus">
              <i class="fas fa-trash"></i>
            </button>
          </div>
        </td>
      `;
      tbody.appendChild(tr);
    });

    const totalPages = Math.ceil(filteredData.length / rowsPerPage) || 1;
    document.getElementById('pageInfo').innerText = `Menampilkan ${start + 1}-${Math.min(end, filteredData.length)} dari ${filteredData.length} data`;
    document.getElementById('btnPrev').disabled = currentPage === 1;
    document.getElementById('btnNext').disabled = currentPage === totalPages;
  }

  // 6. Simpan Data Transaksi
  document.getElementById('formKas').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Ambil elemen tombol di awal agar bisa diakses di seluruh scope fungsi ini
    const btn = document.getElementById('btnSimpan');
    
    // 1. Ambil data saldo & input
    const saldoSekarang = parseFloat(document.getElementById('txtSaldo').innerText.replace(/[Rp,. ]/g, '')) || 0;
    const jenis = document.getElementById('jenis').value;
    const inputRaw = document.getElementById('jumlah').value;
    const jumlahInput = parseFloat(inputRaw.replace(/\./g, '')) || 0;
    const uraian = document.getElementById('uraian').value;
    const tanggal = document.getElementById('tanggal').value;

    // 2. Validasi Dasar
    if (jumlahInput <= 0) {
      Swal.fire('Peringatan', 'Jumlah uang harus lebih dari 0', 'warning');
      return;
    }

    // 3. Validasi Saldo (Khusus Pengeluaran baru / Non-Edit)
    if (jenis === "Pengeluaran" && jumlahInput > saldoSekarang) {
    Swal.fire({
      icon: 'error',
      title: 'Saldo Tidak Mencukupi!',
      text: `Anda mencoba mengeluarkan Rp ${jumlahInput.toLocaleString('id-ID')}, sedangkan saldo kas saat ini hanya Rp ${saldoSekarang.toLocaleString('id-ID')}.`,
      confirmButtonColor: '#232526',
      borderRadius: '20px'
    });
    return; // Berhenti di sini, tidak lanjut simpan
  }

    // 4. UI State: Aktifkan Loader & Loading Tombol
    toggleFullLoader(true); 
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Memproses...';

    // Ambil status sebelum direset
    const wasEditing = isEditMode;
    const targetFunction = isEditMode ? 'updateData' : 'simpanData';

    const obj = {
      no: isEditMode ? editNo : null,
      tanggal: tanggal,
      jenis: jenis,
      uraian: uraian,
      jumlah: jumlahInput
    };

    // 5. Jalankan Fungsi Server
    google.script.run
    .withSuccessHandler(() => {
      // Matikan loader layar penuh agar Swal muncul
      toggleFullLoader(false);

      // Reset Form & State
      document.getElementById('formKas').reset();
      if (fpTanggal) fpTanggal.setDate(new Date()); 
      isEditMode = false;
      editNo = null;

      // Kembalikan Tampilan UI
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save me-2"></i> Simpan Data';
      document.querySelector('#modalTransaksi .modal-title').innerHTML = '<i class="fas fa-plus-circle me-2"></i> Input Transaksi Baru';
      
      modalElement.hide(); 
      
      Swal.fire({ 
        icon: 'success', 
        title: 'Berhasil!', 
        text: wasEditing ? 'Data telah diperbarui.' : 'Data berhasil disimpan.',
        showConfirmButton: false, 
        timer: 1500 
      });
      
      // REFRESH DATA
      loadData();
    })
    .withFailureHandler((err) => {
      toggleFullLoader(false);
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save me-2"></i> Simpan Data';
      Swal.fire('Error Server', err.toString(), 'error');
    })[targetFunction](obj);
});

  // 7. Fungsi Utility & Export
  function formatRupiah(angka) {
    var number_string = angka.replace(/[^,\d]/g, '').toString(),
      split = number_string.split(','),
      sisa = split[0].length % 3,
      rupiah = split[0].substr(0, sisa),
      ribuan = split[0].substr(sisa).match(/\d{3}/gi);
    if (ribuan) {
      separator = sisa ? '.' : '';
      rupiah += separator + ribuan.join('.');
    }
    return rupiah;
  }

  document.getElementById('jumlah').addEventListener('keyup', function() {
    this.value = formatRupiah(this.value);
  });

  function formatTanggalIndo(dateString) {
    if (!dateString || !dateString.includes("-")) return dateString;
    const [year, month, day] = dateString.split("-");
    return `${day}/${month}/${year}`;
  }

  function toggleDateInputs() {
    const isCustom = document.getElementById('rangeCustom').checked;
    document.getElementById('dateInputSection').style.display = isCustom ? 'block' : 'none';
  }

  function processExportPDF() {
    const rangeType = document.querySelector('input[name="rangeType"]:checked').value;
    let dataToExport = [];
    let periodText = "SEMUA DATA";

    if (rangeType === 'all') {
      dataToExport = [...rawData];
    } else {
      const start = document.getElementById('exportStart').value;
      const end = document.getElementById('exportEnd').value;
      if (!start || !end) {
        Swal.fire('Peringatan', 'Pilih rentang tanggal!', 'warning');
        return;
      }
      dataToExport = rawData.filter(row => row[1] >= start && row[1] <= end);
      periodText = `${formatTanggalIndo(start)} s/d ${formatTanggalIndo(end)}`;
    }

    if (dataToExport.length === 0) {
      Swal.fire('Info', 'Data tidak ditemukan', 'info');
      return;
    }

    bootstrap.Modal.getInstance(document.getElementById('modalExport')).hide();
    generatePDF(dataToExport, periodText);
  }

  function generatePDF(dataArray, periodLabel) {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF('p', 'mm', 'a4');
  
  // 1. Header: Judul Laporan
  doc.setFont("helvetica", "bold");
  doc.setFontSize(18);
  doc.text("LAPORAN KAS KEUANGAN", 105, 20, { align: 'center' });
  
  // 2. Sub-Header: Periode (TAMBAHAN BARU)
  doc.setFontSize(11);
  doc.setFont("helvetica", "bold"); // Dibuat Bold agar jelas
  doc.text("Periode: " + periodLabel, 105, 27, { align: 'center' });
  
  // 3. Sub-Header: Tanggal Cetak (Geser ke bawah sedikit)
  doc.setFontSize(10);
  doc.setFont("helvetica", "normal");
  const tglCetak = new Date().toLocaleString('id-ID', { 
    year: 'numeric', month: 'numeric', day: 'numeric', 
    hour: '2-digit', minute: '2-digit', second: '2-digit' 
  });
  doc.text("Dicetak pada: " + tglCetak, 105, 33, { align: 'center' });

  let runningBalance = 0;
  let totalMasuk = 0;
  let totalKeluar = 0;

  // ... (Mapping Data tetap sama seperti sebelumnya) ...
  const rows = dataArray.map((row, index) => {
    let jml = parseFloat(row[4].toString().replace(/[Rp,. ]/g, '')) || 0;
    let masuk = row[2] === 'Penerimaan' ? jml : 0;
    let keluar = row[2] === 'Pengeluaran' ? jml : 0;
    totalMasuk += masuk; totalKeluar += keluar; runningBalance += (masuk - keluar);

    return [
      index + 1,
      formatTanggalIndo(row[1]),
      row[3],
      masuk > 0 ? 'Rp ' + masuk.toLocaleString('id-ID') : '-',
      keluar > 0 ? 'Rp ' + keluar.toLocaleString('id-ID') : '-',
      'Rp ' + runningBalance.toLocaleString('id-ID')
    ];
  });

  // 4. Konfigurasi Tabel (Sesuaikan startY agar tidak menabrak header)
  doc.autoTable({
    head: [['No', 'Tanggal', 'Uraian', 'Penerimaan', 'Pengeluaran', 'Saldo']],
    body: rows,
    startY: 40, // DIUBAH DARI 38 KE 40 AGAR ADA JARAK
    theme: 'grid',
    styles: { 
      fontSize: 9, 
      cellPadding: 3,
      lineWidth: 0.1,
      lineColor: [200, 200, 200]
    },
    headStyles: { 
      fillColor: [35, 37, 38],    // Header Hitam
      textColor: [255, 255, 255], 
      halign: 'center',
      lineWidth: 0.1,
      lineColor: [35, 37, 38]     // Garis header mengikuti warna background
    },
    columnStyles: {
      0: { halign: 'center', cellWidth: 12 },
      1: { halign: 'center', cellWidth: 30 },
      2: { halign: 'left' },
      3: { halign: 'right', cellWidth: 35 },
      4: { halign: 'right', cellWidth: 35 },
      5: { halign: 'right', cellWidth: 35, fontStyle: 'bold' }
    }
  });

  // 5. Bagian Ringkasan (Footer)
  const finalY = doc.lastAutoTable.finalY + 15;
  
  doc.setFont("helvetica", "bold");
  doc.setFontSize(11);
  doc.text("RINGKASAN:", 14, finalY);
  
  doc.setFont("helvetica", "normal");
  doc.text("Total Penerimaan  : Rp " + totalMasuk.toLocaleString('id-ID'), 14, finalY + 8);
  doc.text("Total Pengeluaran : Rp " + totalKeluar.toLocaleString('id-ID'), 14, finalY + 14);
  
  // 6. Kotak Saldo Akhir dengan Border Halus
  doc.setFillColor(245, 245, 245); 
  doc.setDrawColor(200, 200, 200); // Warna border kotak
  doc.rect(14, finalY + 19, 90, 10, 'FD'); // 'FD' artinya Fill and Draw (Isi dan Garis)
  
  doc.setFont("helvetica", "bold");
  doc.text("SALDO AKHIR", 20, finalY + 25.5);
  doc.text(": Rp " + runningBalance.toLocaleString('id-ID'), 55, finalY + 25.5);

  // 7. Simpan File
  const namaFile = periodLabel === "SEMUA DATA" ? "Laporan_Kas_Semua.pdf" : `Laporan_Kas_${periodLabel}.pdf`;
  doc.save(namaFile.replace(/[/ ]/g, '_'));
}

function editData(no) {
  const data = rawData.find(r => r[0] == no);
  if (!data) return;

  isEditMode = true;
  editNo = no;

  // Isi Form Modal
  fpTanggal.setDate(data[1]);
  document.getElementById('jenis').value = data[2];
  document.getElementById('uraian').value = data[3];
  document.getElementById('jumlah').value = formatRupiah(data[4].toString());

  // Ubah Tampilan Modal
  document.querySelector('#modalTransaksi .modal-title').innerHTML = '<i class="fas fa-edit me-2"></i> Edit Transaksi';
  document.getElementById('btnSimpan').innerHTML = '<i class="fas fa-check me-2"></i> Update Data';
  
  modalElement.show();
}

function changeRowsPerPage() {
  const select = document.getElementById('rowsPerPageSelect');
  // Update nilai rowsPerPage berdasarkan pilihan user
  rowsPerPage = parseInt(select.value);
  
  // Reset ke halaman 1 agar tidak terjadi error index
  currentPage = 1;
  
  // Render ulang tabel dengan jumlah baris baru
  renderTable();
}

// Fungsi Konfirmasi Hapus
function konfirmasiHapus(no) {
  Swal.fire({
    title: 'Hapus Transaksi?',
    text: "Data akan dihapus permanen.",
    icon: 'warning',
    showCancelButton: true,
    confirmButtonColor: '#d33',
    confirmButtonText: 'Ya, Hapus!',
    cancelButtonText: 'Batal'
  }).then((result) => {
    if (result.isConfirmed) {
      toggleFullLoader(true);

      google.script.run
        .withSuccessHandler((isSuccess) => {
          if (isSuccess) {
            // --- TRIK AGAR INSTAN: UPDATE LOKAL ---
            // Hapus data dari variabel rawData di browser
            rawData = rawData.filter(row => row[0] != no);
            
            // Jalankan filter & render ulang tabel (Saldo otomatis terhitung ulang)
            applyFilter(); 
            
            // Matikan loading SEGERA
            toggleFullLoader(false);

            Swal.fire({
              icon: 'success',
              title: 'Data Berhasil dihapus!',
              showConfirmButton: false,
              timer: 1000 // Perkecil timer agar lebih cepat
            });
          }
        })
        .withFailureHandler((err) => {
          toggleFullLoader(false);
          Swal.fire('Error', 'Gagal hapus: ' + err, 'error');
        })
        .hapusData(no);
    }
  });
}

  // Navigasi Tabel
  document.getElementById('searchInput').addEventListener('input', () => { currentPage = 1; applyFilter(); });
  function prevPage() { if(currentPage > 1) { currentPage--; renderTable(); } }
  function nextPage() { if((currentPage * rowsPerPage) < filteredData.length) { currentPage++; renderTable(); } }

  // Listener otomatis saat modal ditutup
document.getElementById('modalTransaksi').addEventListener('hidden.bs.modal', function () {
  // 1. Reset Form (Mengosongkan semua input)
  document.getElementById('formKas').reset();
  
  // 2. Reset Tanggal ke hari ini (Flatpickr)
  if (fpTanggal) {
    fpTanggal.setDate(new Date());
  }

  // 3. Pastikan tombol X pada input jumlah hilang (jika ada)
  // (Jika Anda punya tombol clear di input jumlah)

  // 4. Reset State Edit Mode (Sangat Penting!)
  isEditMode = false;
  editNo = null;

  // 5. Kembalikan judul modal dan teks tombol ke default (Tambah)
  document.querySelector('#modalTransaksi .modal-title').innerHTML = '<i class="fas fa-edit me-2"></i> Input Transaksi Baru';
  const btn = document.getElementById('btnSimpan');
  btn.innerHTML = '<i class="fas fa-save me-2"></i> Simpan Data';
  btn.disabled = false; // Pastikan tombol tidak dalam keadaan loading
});
</script>

